<?xml version="1.0"?>
<robot name="my_clean_robot">
  <link name="link0"/>

  <joint name="joint_1" type="revolute">
    <parent link="link0"/>
    <child link="link1"/>
    <origin xyz="-0.0155 0 0.059" rpy="0 0 0"/> <axis xyz="0 0 1"/> 
    <limit lower="-1.57" upper="1.57"/>
  </joint>
  <link name="link1"/>

  <joint name="joint_2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0.0245 0.045828" rpy="0 0 0"/> <axis xyz="0 1 0"/> <limit lower="-0.524" upper="2.007"/>
  </joint>
  <link name="link2"/>

  <joint name="joint_3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="-0.1525 -0.005544 0.000022" rpy="0 0 0"/> <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57"/>
  </joint>
  <link name="link3"/>

  <joint name="joint_4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.1235 0 0" rpy="0 0 0"/> <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="2.0"/>
  </joint>
  <link name="link4"/>

  <joint name="joint_5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="-0.06165 -0.018950 0.0085" rpy="0 0 0"/> <axis xyz="1 0 0"/> <limit lower="-1.57" upper="1.57"/>
  </joint>
  <link name="link5"/>

  <joint name="tcp_joint" type="fixed"> <parent link="link5"/>
    <child link="link_tcp"/>
    <origin xyz="-0.13 0 0" rpy="0 0 0"/> </joint>
  <link name="link_tcp"/>

</robot>
